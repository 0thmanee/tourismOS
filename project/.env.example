# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Database (PostgreSQL)
DATABASE_URL="postgresql://betox:betoxbe@localhost:5432/origine_maroc?connection_limit=5"

# Better Auth — generate secret with: npx @better-auth/cli@latest secret
BETTER_AUTH_SECRET="your-generated-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Resend — for email verification (https://resend.com/api-keys)
# Without RESEND_API_KEY, verification emails are skipped (dev-only).
RESEND_API_KEY="re_..."

# Optional: verified sender address (e.g. noreply@yourdomain.com).
# Omit to use Resend's test sender (onboarding@resend.dev).
# RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Supabase — for media (profile pictures, product images). Create one public bucket in Storage (e.g. "origine-maroc").
# https://supabase.com/dashboard/project/your-project-id/storage/buckets
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Bucket name where all images are stored (must exist and be public).
SUPABASE_STORAGE_BUCKET="origine-maroc"
# Optional: same URL, used to build public image URLs (defaults to SUPABASE_URL if unset).
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"