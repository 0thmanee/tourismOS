// TourismOS — Prisma schema (MVP bookings + auth/org only)
// Keeps Better Auth models + organization multi-tenancy.
// Booking inbox MVP models are tenant-scoped by `organizationId`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── App enums (user) ───────────────────────────────────────────────────────
enum UserRole {
  partner
  superadmin
}

enum UserStatus {
  disabled // pending admin approval
  enabled // can access /producer
}

// Activity catalog — drives booking behavior (same UI, different rules)
enum ActivityKind {
  FIXED_SLOT // time slots + capacity
  FLEXIBLE // on-demand, operator confirms
  MULTI_DAY // date range
  RESOURCE_BASED // equipment/units capacity
}

enum PricingKind {
  PER_PERSON
  PER_GROUP
}

// ─── Better Auth (core) ─────────────────────────────────────────────────────
model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  emailVerified    Boolean    @default(false)
  image            String?
  role             UserRole   @default(partner)
  status           UserStatus @default(disabled) // first user set enabled + superadmin
  profileCompleted Boolean    @default(false)     // onboarding done
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  sessions         Session[]
  accounts         Account[]
  members          Member[]
  profile          Profile?
  /** B2C app: bookings created while signed in as this traveler */
  travelerBookings Booking[] @relation("BookingTraveler")

  @@map("user")
}

// Onboarding / partner profile (filled after email verification)
model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  phone              String
  entityType         String // Individual Producer | Cooperative | Company / SARL | Association
  entityName         String
  registrationNumber String?
  region             String
  city               String
  yearEstablished    String?
  website            String?
  categories         Json // string[] product category labels
  annualCapacity     String?
  exportExperience   String?
  agreeTerms         Boolean  @default(true)
  agreeMarketing     Boolean  @default(false)
  profileImage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("profile")
}

model Session {
  id                     String   @id @default(cuid())
  expiresAt              DateTime
  token                  String   @unique
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  ipAddress              String?
  userAgent              String?
  userId                 String
  activeOrganizationId   String?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─── Better Auth Organization plugin (multi-tenant) ───────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       Member[]
  invitations   Invitation[]

  // App tenant-scoped relations
  customers Customer[]
  bookings  Booking[]
  staffMembers StaffMember[]
  settings  OrganizationSettings?
  activitiesCatalog Activity[]

  @@map("organization")
}

model Activity {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  kind        ActivityKind
  pricingKind PricingKind @default(PER_PERSON)

  /** Max participants (people) — used for FIXED_SLOT / FLEXIBLE / MULTI_DAY */
  capacity        Int?
  /** For RESOURCE_BASED: max units (quads, boards) at once */
  resourceCapacity Int?

  /** JSON string[] "HH:mm" for FIXED_SLOT */
  fixedSlots       Json     @default("[]")
  /** JSON number[] — selectable day counts for MULTI_DAY */
  durationOptions  Json     @default("[1,2,3]")
  defaultDurationDays Int  @default(1)

  requiresGuide     Boolean @default(false)
  requiresTransport Boolean @default(false)
  requiresEquipment Boolean @default(false)

  defaultPriceMad Int?
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([organizationId])
  @@index([kind])
  @@map("activity")
}

// MVP Step 1: operator business settings (activities + pricing presets)
model OrganizationSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /** Display name override; falls back to Organization.name if empty */
  businessName   String?
  /** string[] activity labels for quick picks */
  activities     Json     @default("[]")
  /** { label: string, priceMad: number }[] */
  pricingPresets Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("organization_settings")
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String // owner | admin | member (or custom)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String
  status         String // pending | accepted | rejected | cancelled
  expiresAt      DateTime
  createdAt      DateTime? @default(now())
  updatedAt      DateTime? @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Booking inbox MVP (tenant-scoped) ───────────────────────────────────────
model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([organizationId])
  @@index([phone])
  @@map("customer")
}

model Booking {
  id             String   @id @default(cuid())
  organizationId String

  /** When set, this booking is owned by the signed-in B2C user (see list/detail access). */
  travelerUserId String?
  travelerUser   User?    @relation("BookingTraveler", fields: [travelerUserId], references: [id], onDelete: SetNull)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  /** Optional link to catalog activity (legacy rows may be null) */
  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  /** Denormalized from Activity.kind at booking time */
  activityKind ActivityKind?

  activityTitle String
  startAt       DateTime
  /** End instant for multi-day / range display (inclusive planning) */
  endAt         DateTime?

  peopleCount Int
  priceCents  Int

  /** Type-specific payload: slotTime, resourceUnits, durationDays, etc. */
  meta Json?

  // Inbox status
  status        String @default("NEW") // NEW | PENDING | CONFIRMED | CANCELLED

  // Payment status (MVP)
  paymentStatus String @default("UNPAID") // UNPAID | DEPOSIT | PAID
  depositCents  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     BookingMessage[]
  assignments  BookingAssignment[]

  @@index([organizationId])
  @@index([status])
  @@index([startAt])
  @@index([activityId])
  @@index([travelerUserId])
  @@map("booking")
}

model StaffMember {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  role           String // GUIDE | DRIVER | COORDINATOR
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  BookingAssignment[]

  @@index([organizationId])
  @@index([role])
  @@map("staff_member")
}

model BookingAssignment {
  id            String   @id @default(cuid())
  bookingId     String
  staffMemberId String
  assignmentRole String? // GUIDE | DRIVER | COORDINATOR | custom label
  notes         String?
  createdAt     DateTime @default(now())

  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@unique([bookingId, staffMemberId])
  @@index([bookingId])
  @@index([staffMemberId])
  @@map("booking_assignment")
}

model BookingMessage {
  id        String   @id @default(cuid())
  bookingId String
  sender    String // CUSTOMER | OPERATOR | SYSTEM
  type      String   @default("TEXT") // TEXT | SYSTEM | PROPOSAL | REQUEST_INFO | LOGISTICS
  body      String  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_message")
}

